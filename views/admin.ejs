<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lumiskin Admin</title>
    <link rel="stylesheet" href="/css/admin.css">
    <style>
        /* ── File Upload Styling ─────────────────────────────────── */
        .upload-label {
            display: block;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 0.08em;
            color: #999;
            text-transform: uppercase;
            margin-bottom: 4px;
        }
        .upload-input {
            width: 100%;
            padding: 8px 10px;
            border: 1px dashed #444;
            border-radius: 6px;
            background: #1e1e1e;
            color: #ccc;
            font-size: 13px;
            cursor: pointer;
        }
        .upload-input:hover { border-color: #a36c45; }
        .upload-preview {
            width: 60px; height: 60px;
            object-fit: cover;
            border-radius: 6px;
            margin-top: 6px;
            border: 1px solid #333;
            display: none;
        }
        /* ── Toast notification ──────────────────────────────────── */
        #admin-toast {
            position: fixed; bottom: 28px; left: 50%;
            transform: translateX(-50%) translateY(20px);
            background: #2e7d32; color: #fff;
            padding: 12px 28px; border-radius: 50px;
            font-size: 14px; font-weight: 700;
            z-index: 9999; opacity: 0;
            transition: all 0.3s ease; pointer-events: none;
        }
        #admin-toast.error { background: #c62828; }
        #admin-toast.show  { opacity: 1; transform: translateX(-50%) translateY(0); }
        /* ── Product thumbnail in table ──────────────────────────── */
        .prod-thumb {
            width: 44px; height: 44px;
            object-fit: cover; border-radius: 4px;
            border: 1px solid #333; vertical-align: middle;
        }
        /* ── Loading spinner on submit ───────────────────────────── */
        .btn-add:disabled { opacity: 0.6; cursor: not-allowed; }
    </style>
</head>
<body>

<nav class="sidebar">
    <h2>LUMISKIN</h2>
    <p style="color:#ccc; font-size:13px; padding: 0 16px;">Welcome, <%= user %></p>
    <ul>
        <li onclick="showSection('dashboard')">Overview</li>
        <li onclick="showSection('products')">Manage Products</li>
        <li onclick="showSection('users')">Manage Users</li>
    </ul>
    <a href="/" class="return-home-card">
        <div class="return-home-content">
            <span class="home-icon">⌂</span>
            <div><h3>Return To Home</h3></div>
        </div>
    </a>
    <a href="/user/logout" style="color:#ccc; padding:16px; display:block; margin-top:20px;">Logout</a>
</nav>

<main class="main-content">

    <!-- DASHBOARD OVERVIEW -->
    <div id="dashboardSection" class="management-section">
        <h1>Dashboard Overview</h1>
        <div class="card-row">
            <div class="card">
                <small>TOTAL PRODUCTS</small>
                <h2 class="stat-value" id="productCount"><%= products.length %></h2>
            </div>
            <div class="card">
                <small>TOTAL REGISTERED USERS</small>
                <h2 class="stat-value"><%= users.length %></h2>
            </div>
        </div>
    </div>

    <!-- MANAGE PRODUCTS -->
    <div id="productsSection" class="management-section" style="display:none;">
        <h1>Manage Products</h1>

        <!-- ── Add Product Form (multipart for file upload) ──────────────── -->
        <form id="addProductForm" enctype="multipart/form-data"
              style="display:flex; flex-wrap:wrap; gap:10px; margin-bottom:30px; align-items:flex-end;">

            <input type="text"   name="name"     placeholder="Product Name" required>
            <input type="text"   name="brand"    placeholder="Brand" required>
            <input type="number" name="price"    placeholder="Price (EGP)" required>
            <input type="text"   name="category" placeholder="Category (e.g. Cleanser)">
            <input type="text"   name="tag"      placeholder="Tag (e.g. CLEANSE)">

            <!-- ── Primary image upload ──────────────────────────────────── -->
            <div style="display:flex; flex-direction:column;">
                <span class="upload-label">Product Image</span>
                <input type="file" name="image" accept="image/*"
                       class="upload-input" id="imgInput"
                       onchange="previewImage(this,'imgPreview')">
                <img id="imgPreview" class="upload-preview" alt="preview">
            </div>

            <!-- ── Hover / secondary image upload ────────────────────────── -->
            <div style="display:flex; flex-direction:column;">
                <span class="upload-label">Hover Image (optional)</span>
                <input type="file" name="image2" accept="image/*"
                       class="upload-input" id="img2Input"
                       onchange="previewImage(this,'img2Preview')">
                <img id="img2Preview" class="upload-preview" alt="preview">
            </div>

            <button type="submit" class="btn-add" id="addBtn">+ Add Product</button>
        </form>

        <!-- Products Table -->
        <table>
            <thead>
                <tr>
                    <th>IMG</th>
                    <th>NAME</th>
                    <th>BRAND</th>
                    <th>PRICE</th>
                    <th>CATEGORY</th>
                    <th>TAG</th>
                    <th>ACTIONS</th>
                </tr>
            </thead>
            <tbody id="productsTableBody">
                <% if (products.length === 0) { %>
                    <tr id="emptyProductsRow">
                        <td colspan="7" style="text-align:center;">
                            No products yet. Add one above!
                        </td>
                    </tr>
                <% } %>
                <% products.forEach(product => { %>
                <tr id="product-row-<%= product._id %>">
                    <td>
                        <% if (product.image) { %>
                            <img src="/images/<%= product.image %>" alt="<%= product.name %>" class="prod-thumb">
                        <% } else { %>
                            <span style="color:#666; font-size:11px;">No img</span>
                        <% } %>
                    </td>
                    <td><%= product.name %></td>
                    <td><%= product.brand %></td>
                    <td><%= product.price %> EGP</td>
                    <td><%= product.category %></td>
                    <td><%= product.tag %></td>
                    <td>
                        <a href="/admin/edit-product/<%= product._id %>"
                           style="color:#a36c45; margin-right:10px;">Edit</a>
                        <button onclick="ajaxDeleteProduct('<%= product._id %>', '<%= product.name %>')"
                                style="background:none; border:none; color:red; cursor:pointer;
                                       font-size:14px; padding:0;">
                            Delete
                        </button>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>

    <!-- MANAGE USERS -->
    <div id="userSection" class="management-section" style="display:none;">
        <h1>Manage Users</h1>
        <table>
            <thead>
                <tr>
                    <th>NAME</th>
                    <th>EMAIL</th>
                    <th>ACTIONS</th>
                </tr>
            </thead>
            <tbody id="usersTableBody">
                <% if (users.length === 0) { %>
                    <tr id="emptyUsersRow">
                        <td colspan="3" style="text-align:center;">No users registered yet.</td>
                    </tr>
                <% } %>
                <% users.forEach(u => { %>
                <tr id="user-row-<%= u._id %>">
                    <td><%= u.name %></td>
                    <td><%= u.email %></td>
                    <td>
                        <a href="/admin/edit-user/<%= u._id %>"
                           style="color:#a36c45; margin-right:10px;">Edit</a>
                        <button onclick="ajaxDeleteUser('<%= u._id %>', '<%= u.name %>')"
                                style="background:none; border:none; color:red; cursor:pointer;
                                       font-size:14px; padding:0;">
                            Delete
                        </button>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>

</main>

<!-- Toast -->
<div id="admin-toast"></div>

<script src="/js/admin.js"></script>
</body>
</html>
