<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Profile — Lumiskin</title>
    <link rel="stylesheet" href="/css/header.css">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            background-color: rgb(233, 221, 206);
            min-height: 100vh;
            padding-top: 72px !important;
        }

        .profile-layout {
            display: grid;
            grid-template-columns: 280px 1fr;
            min-height: calc(100vh - 72px);
        }

        /* ── Sidebar ── */
        .profile-sidebar {
            background: rgb(83, 54, 30);
            padding: 48px 32px;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .profile-avatar {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background: rgba(255,255,255,0.15);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Cormorant Garamond', serif;
            font-size: 32px;
            color: #fff;
            margin-bottom: 20px;
            border: 2px solid rgba(255,255,255,0.2);
        }

        .profile-name {
            font-family: 'Cormorant Garamond', serif;
            font-size: 22px;
            color: #fff;
            font-weight: 400;
            margin-bottom: 4px;
        }

        .profile-email {
            font-size: 12px;
            color: rgba(255,255,255,0.5);
            letter-spacing: 0.04em;
            margin-bottom: 32px;
        }

        .sidebar-nav-item {
            padding: 12px 16px;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 500;
            letter-spacing: 0.06em;
            text-transform: uppercase;
            color: rgba(255,255,255,0.6);
            cursor: pointer;
            transition: all 0.2s ease;
            text-decoration: none;
            display: block;
        }

        .sidebar-nav-item:hover,
        .sidebar-nav-item.active {
            background: rgba(255,255,255,0.1);
            color: #fff;
        }

        .sidebar-logout {
            margin-top: auto;
            padding: 12px 16px;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 500;
            letter-spacing: 0.06em;
            text-transform: uppercase;
            color: rgba(255,255,255,0.4);
            text-decoration: none;
            display: block;
            transition: all 0.2s ease;
            border-top: 1px solid rgba(255,255,255,0.1);
            padding-top: 20px;
            margin-top: auto;
        }

        .sidebar-logout:hover {
            color: #fff;
        }

        /* ── Main Content ── */
        .profile-main {
            padding: 60px;
            background: rgb(248, 243, 238);
            overflow-y: auto;
        }

        .profile-header {
            margin-bottom: 48px;
            padding-bottom: 28px;
            border-bottom: 1px solid rgba(163, 108, 69, 0.12);
        }

        .profile-eyebrow {
            font-size: 11px;
            font-weight: 600;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: rgb(163, 108, 69);
            margin-bottom: 10px;
        }

        .profile-title {
            font-family: 'Cormorant Garamond', serif;
            font-size: 42px;
            font-weight: 400;
            color: rgb(83, 54, 30);
            line-height: 1.1;
        }

        .profile-subtitle {
            font-size: 14px;
            color: #999;
            margin-top: 8px;
        }

        /* ── Form ── */
        .profile-form {
            max-width: 560px;
        }

        .form-section-title {
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 0.18em;
            text-transform: uppercase;
            color: rgb(147, 97, 62);
            margin-bottom: 20px;
            margin-top: 36px;
            padding-top: 28px;
            border-top: 1px solid rgba(163, 108, 69, 0.1);
        }

        .form-section-title:first-child {
            border-top: none;
            margin-top: 0;
            padding-top: 0;
        }

        .field-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
        }

        .field {
            margin-bottom: 20px;
        }

        .field label {
            display: block;
            font-size: 11px;
            font-weight: 600;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: rgb(147, 97, 62);
            margin-bottom: 8px;
        }

        .field input {
            width: 100%;
            padding: 13px 16px;
            border: 1.5px solid rgba(163, 108, 69, 0.18);
            border-radius: 8px;
            font-size: 14px;
            font-family: 'Jost', sans-serif;
            background: #fff;
            color: rgb(83, 54, 30);
            outline: none;
            transition: border-color 0.2s ease, box-shadow 0.2s ease;
        }

        .field input:focus {
            border-color: rgb(163, 108, 69);
            box-shadow: 0 0 0 3px rgba(163, 108, 69, 0.08);
        }

        .field input::placeholder {
            color: #ccc;
            font-weight: 300;
        }

        .field-hint {
            font-size: 11px;
            color: #bbb;
            margin-top: 6px;
            line-height: 1.5;
        }

        .form-actions {
            display: flex;
            gap: 12px;
            margin-top: 32px;
            align-items: center;
        }

        .btn-save {
            padding: 14px 32px;
            background: rgb(83, 54, 30);
            color: #fff;
            border: none;
            border-radius: 8px;
            font-size: 12px;
            font-weight: 600;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            font-family: 'Jost', sans-serif;
            cursor: pointer;
            transition: background 0.3s ease, transform 0.2s ease;
        }

        .btn-save:hover {
            background: rgb(147, 97, 62);
            transform: translateY(-1px);
        }

        .btn-cancel {
            padding: 14px 24px;
            background: transparent;
            color: #bbb;
            border: 1.5px solid rgba(163, 108, 69, 0.15);
            border-radius: 8px;
            font-size: 12px;
            font-weight: 600;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            font-family: 'Jost', sans-serif;
            text-decoration: none;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .btn-cancel:hover {
            border-color: rgb(147, 97, 62);
            color: rgb(147, 97, 62);
        }

        .success-msg {
            display: flex;
            align-items: center;
            gap: 10px;
            background: #e8f5e9;
            color: #27ae60;
            border-radius: 8px;
            padding: 14px 18px;
            font-size: 13px;
            margin-bottom: 28px;
            border-left: 3px solid #27ae60;
            font-weight: 500;
        }

        .error-msg {
            display: flex;
            align-items: center;
            gap: 10px;
            background: #fdecea;
            color: #c0392b;
            border-radius: 8px;
            padding: 14px 18px;
            font-size: 13px;
            margin-bottom: 28px;
            border-left: 3px solid #c0392b;
            font-weight: 500;
        }
    </style>
</head>
<body>

<%- include('partials/header') %>

<div class="profile-layout">

    <!-- Sidebar -->
    <div class="profile-sidebar">
        <div class="profile-avatar">
            <%= userData.name.charAt(0).toUpperCase() %>
        </div>
        <div class="profile-name"><%= userData.name %></div>
        <div class="profile-email"><%= userData.email %></div>

        <a href="/user/profile" class="sidebar-nav-item active">Edit Profile</a>
        <a href="/" class="sidebar-nav-item">Home</a>
        <a href="/user/cart" class="sidebar-nav-item">My Cart</a>
    <a href="#purchases" class="sidebar-nav-item" onclick="showProfileSection('purchases')">Last Purchases</a>
    <a href="#quiz" class="sidebar-nav-item" onclick="showProfileSection('quiz')">My Skin Profile</a>

        <a href="/user/logout" class="sidebar-logout">Sign Out</a>
    </div>

    <!-- Main -->
    <div class="profile-main">
        <div id="editSection">
            <% if (error !== '') { %>
                <div class="error-msg">⚠ <%= error %></div>
            <% } %>
            <% if (success !== '') { %>
                <div class="success-msg">✓ <%= success %></div>
            <% } %>

            <div class="profile-header">
                <p class="profile-eyebrow">Account Settings</p>
                <h1 class="profile-title">Edit Profile</h1>
                <p class="profile-subtitle">Update your personal information and password.</p>
            </div>

        <form class="profile-form" action="/user/profile" method="POST">

            <p class="form-section-title">Personal Information</p>

            <div class="field-row">
                <div class="field">
                    <label>First Name</label>
                    <input type="text" name="fname"
                           value="<%= userData.name.split(' ')[0] %>" required>
                </div>
                <div class="field">
                    <label>Last Name</label>
                    <input type="text" name="lname"
                           value="<%= userData.name.split(' ')[1] || '' %>">
                </div>
            </div>

            <div class="field">
                <label>Email Address</label>
                <input type="email" name="email"
                       value="<%= userData.email %>" required>
            </div>

            <p class="form-section-title">Change Password</p>

            <div class="field">
                <label>New Password</label>
                <input type="password" name="password"
                       placeholder="Leave empty to keep current password">
                <p class="field-hint">Must be at least 8 characters with one uppercase letter and one number.</p>
            </div>

            <div class="field">
                <label>Confirm New Password</label>
                <input type="password" name="confirmPassword"
                       placeholder="Repeat new password">
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-save">Save Changes</button>
                <a href="/" class="btn-cancel">Cancel</a>
            </div>

        </form>
        </div>

        <div id="purchasesSection" style="display:none;">
    <div class="profile-header">
        <p class="profile-eyebrow">Purchase History</p>
        <h1 class="profile-title">Last Purchases</h1>
        <p class="profile-subtitle">Your recent orders from Lumiskin.</p>
    </div>

    <% if (userData.purchases && userData.purchases.length > 0) { %>
        <div style="max-width:600px;">
            <% userData.purchases.slice().reverse().forEach((p, i) => { %>
            <div style="background:#fff; border-radius:12px; padding:18px 24px;
                        margin-bottom:12px; display:flex; justify-content:space-between;
                        align-items:center; box-shadow:0 2px 8px rgba(0,0,0,0.05);
                        border-left:3px solid rgb(206,110,26);">
                <div>
                    <p style="font-weight:600; color:rgb(83,54,30); font-size:15px; margin-bottom:4px;">
                        <%= p.name %>
                    </p>
                    <p style="font-size:12px; color:#aaa;">
                        <%= new Date(p.date).toLocaleDateString('en-GB', { day:'numeric', month:'long', year:'numeric' }) %>
                    </p>
                </div>
                <p style="font-weight:700; color:rgb(206,110,26); font-size:16px; white-space:nowrap;">
                    <%= p.price %> EGP
                </p>
            </div>
            <% }) %>
        </div>
    <% } else { %>
        <div style="text-align:center; padding:60px 20px;">
            <p style="font-size:40px; margin-bottom:16px;">🛒</p>
            <p style="font-size:18px; color:#aaa; margin-bottom:24px;">No purchases yet.</p>
            <a href="/#brand-section" style="background:rgb(83,54,30); color:#fff;
                padding:12px 28px; border-radius:8px; text-decoration:none;
                font-weight:600; font-size:13px; letter-spacing:0.08em; text-transform:uppercase;">
                Shop Now
            </a>
        </div>
    <% } %>
        </div>

        <div id="quizSection" style="display:none;">
            <div class="profile-header">
                <p class="profile-eyebrow">Quiz Result</p>
        <h1 class="profile-title">My Skin Profile</h1>
        <p class="profile-subtitle">Based on your last skin quiz result.</p>
    </div>

    <% if (userData.quizResult && userData.quizResult !== '') { %>
        <div style="max-width:500px; background:#fff; border-radius:16px; padding:32px;
                    box-shadow:0 4px 20px rgba(0,0,0,0.06);">
            <p style="font-size:11px; font-weight:700; letter-spacing:0.15em;
                      text-transform:uppercase; color:rgb(163,108,69); margin-bottom:12px;">
                Your Skin Profile
            </p>
            <h2 style="font-family:'Cormorant Garamond', serif; font-size:32px;
                       color:rgb(83,54,30); font-weight:400; margin-bottom:20px;">
                <%= userData.quizResult %>
            </h2>
            <a href="/quiz" style="background:rgb(83,54,30); color:#fff; padding:12px 24px;
                border-radius:8px; text-decoration:none; font-weight:600;
                font-size:12px; letter-spacing:0.1em; text-transform:uppercase; display:inline-block;">
                Retake Quiz
            </a>
        </div>
    <% } else { %>
        <div style="text-align:center; padding:60px 20px;">
            <p style="font-size:40px; margin-bottom:16px;">🧴</p>
            <p style="font-size:18px; color:#aaa; margin-bottom:24px;">You haven't taken the quiz yet.</p>
            <a href="/quiz" style="background:rgb(83,54,30); color:#fff;
                padding:12px 28px; border-radius:8px; text-decoration:none;
                font-weight:600; font-size:13px; letter-spacing:0.08em; text-transform:uppercase;">
                Take the Skin Quiz
            </a>
        </div>
    <% } %>
        </div><!-- end quizSection -->

    </div><!-- end profile-main -->
</div><!-- end profile-layout -->

<script>
function showProfileSection(name) {
    // Hide ALL sections
    ['edit', 'purchases', 'quiz'].forEach(s => {
        const el = document.getElementById(s + 'Section');
        if (el) el.style.display = 'none';
    });

    // Show the selected section
    const target = document.getElementById(name + 'Section');
    if (target) target.style.display = 'block';

    // Update active sidebar link styling
    document.querySelectorAll('.sidebar-nav-item').forEach(a => {
        a.classList.remove('active');
        const href = a.getAttribute('href');
        if (href === '#' + name || (name === 'edit' && href === '/user/profile')) {
            a.classList.add('active');
        }
    });

    // Scroll to top of main content
    const main = document.querySelector('.profile-main');
    if (main) main.scrollTop = 0;
}

// Show edit section by default or based on URL hash on page load
document.addEventListener('DOMContentLoaded', () => {
    let section = 'edit';
    const hash = window.location.hash;
    if (hash === '#purchases') {
        section = 'purchases';
    } else if (hash === '#quiz') {
        section = 'quiz';
    }
    showProfileSection(section);
});



  document.querySelectorAll('input[name="fname"], input[name="lname"]').forEach(input => {

    // Create a hint element per field
    const hint = document.createElement('small');
    hint.textContent = 'Numbers are not allowed in name fields.';
    hint.style.cssText = `
      color: #c0392b;
      font-size: 0.78rem;
      margin-top: 4px;
      display: none;
      transition: opacity 0.3s ease;
      opacity: 0;
    `;
    input.insertAdjacentElement('afterend', hint);

    let hideTimer;

    const showHint = () => {
      clearTimeout(hideTimer);
      hint.style.display = 'block';
      // Small delay so display:block renders before opacity transition kicks in
      setTimeout(() => hint.style.opacity = '1', 10);
      hideTimer = setTimeout(() => {
        hint.style.opacity = '0';
        setTimeout(() => hint.style.display = 'none', 300);
      }, 2500); // disappears after 2.5 seconds
    };

    input.addEventListener('keypress', (e) => {
      if (/\d/.test(e.key)) {
        e.preventDefault();
        showHint();
      }
    });

    input.addEventListener('input', () => {
      if (/\d/.test(input.value)) {
        input.value = input.value.replace(/\d/g, '');
        showHint();
      }
    });

    input.addEventListener('paste', (e) => {
      e.preventDefault();
      const pasted = (e.clipboardData || window.clipboardData).getData('text');
      const cleaned = pasted.replace(/\d/g, '');
      input.value = cleaned;
      if (pasted !== cleaned) showHint();
    });
  });


</script>

</body>
</html>
