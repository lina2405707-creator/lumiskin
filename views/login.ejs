<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login — Lumiskin</title>
    <link rel="stylesheet" href="/css/header.css">
    <link rel="stylesheet" href="/css/login.css">
    <link rel="stylesheet" href="/css/darkmode.css">
    <link rel="stylesheet" href="/css/rtl.css">
</head>
<body>

<%- include('partials/header') %>

<div class="auth-layout">
    <!-- Left: Image -->
    <div class="auth-image">
        <img src="/images/skin2.jpg" alt="Skincare">
        <div class="auth-image-overlay"></div>
        <div class="auth-image-quote">
            <p data-i18n="login.quote">"Your skin is a reflection of your inner health."</p>
            <span data-i18n="login.philosophy">Lumiskin Philosophy</span>
        </div>
    </div>

    <!-- Right: Form -->
    <div class="auth-form-panel">
        <div class="auth-form-box">
            <p class="auth-eyebrow" data-i18n="login.eyebrow">Welcome back</p>
            <h1 class="auth-title"  data-i18n="login.title">Sign In</h1>
            <p class="auth-subtitle" data-i18n="login.subtitle">Enter your details to access your account.</p>

            <% if (error !== '') { %>
                <div class="error-msg"><%= error %></div>
            <% } %>

            <form action="/user/login" method="POST" onsubmit="return validateLogin()">
                <div class="field">
                    <label data-i18n="login.email">Email Address</label>
                    <input type="email" name="email"
                           data-i18n-ph="login.email.ph"
                           placeholder="you@example.com" required>
                </div>
                <div class="field">
                    <label data-i18n="login.password">Password</label>
                    <input type="password" name="password"
                           data-i18n-ph="login.password.ph"
                           placeholder="Your password" required>
                </div>
                <button type="submit" class="auth-btn" data-i18n="login.btn">Sign In</button>
            </form>

            <div class="auth-divider"><span data-i18n="login.or">or</span></div>

            <p class="auth-link">
                <span data-i18n="login.noAccount">Don't have an account?</span>
                <a href="/user/signup" data-i18n="login.create">Create one</a>
            </p>
        </div>
    </div>
</div>

<script src="/js/auth.js"></script>
</body>
</html>
