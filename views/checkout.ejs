<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/checkout.css" />
  <link rel="stylesheet" href="/css/darkmode.css" />
  <!-- Apply dark mode instantly before page renders to prevent flash -->
  <script>
    (function() {
      if (localStorage.getItem('lumiskin-theme') === 'dark') {
        document.documentElement.classList.add('dark-mode');
      }
    })();
  </script>
</head>
<body>

  <header class="checkout-header">
    <a href="/" class="logo">LUMISKIN</a>
    <nav class="checkout-breadcrumb" aria-label="Checkout progress">
      <span class="active" data-i18n="checkout.step.checkout">Checkout</span>
      <span class="sep">›</span>
      <span data-i18n="checkout.step.confirmation">Confirmation</span>
    </nav>
    <div class="checkout-header-right">
      <div class="secure-badge">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
        <span data-i18n="checkout.secure">Secure Checkout</span>
      </div>
    </div>
  </header>

  <main>
    <div class="checkout-wrapper">

      <!-- ════ LEFT — FORM ════ -->
      <div class="checkout-form-col">
        <h1 class="checkout-title" data-i18n="checkout.title">Your Details</h1>

        <% if (errors.general) { %>
          <div class="error-banner" role="alert"><%= errors.general %></div>
        <% } %>

        <form id="checkout-form" method="POST" action="/checkout" novalidate>

          <input type="hidden" id="paymentMethod" name="paymentMethod" value="card" />
          <input type="hidden" id="promoCode-hidden" name="promoCode" value="<%= formData.promoCode || '' %>" />

          <!-- ── Section 1: Contact & Shipping ── -->
          <div class="form-section" id="section-contact">
            <div class="section-header" aria-expanded="true">
              <span class="section-number">1</span>
              <span class="section-title" data-i18n="checkout.s1.title">Contact & Shipping</span>
              <svg class="section-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M6 9l6 6 6-6"/>
              </svg>
            </div>

            <div class="section-body">

              <!-- Email -->
              <div class="field-row">
                <div class="field-group">
                  <label for="email" data-i18n="checkout.field.email">Email Address</label>
                  <input type="email" id="email" name="email"
                    data-i18n-ph="checkout.ph.email" placeholder="you@example.com"
                    value="<%= formData.email || '' %>" autocomplete="email"
                    class="<%= errors.email ? 'is-invalid' : '' %>" required />
                  <span class="field-error"><%= errors.email || '' %></span>
                </div>
              </div>

              <!-- Newsletter -->
              <label class="checkbox-row">
                <input type="checkbox" name="subscribe" <%= formData.subscribe === 'on' ? 'checked' : '' %> />
                <span data-i18n="checkout.subscribe">Subscribe to skincare tips and exclusive offers</span>
              </label>

              <!-- Full Name -->
              <div class="field-row">
                <div class="field-group">
                  <label for="fullName" data-i18n="checkout.field.name">Full Name</label>
                  <input type="text" id="fullName" name="fullName"
                    data-i18n-ph="checkout.ph.name" placeholder="Jane Doe"
                    value="<%= formData.fullName || '' %>" autocomplete="name"
                    class="<%= errors.fullName ? 'is-invalid' : '' %>" required />
                  <span class="field-error"><%= errors.fullName || '' %></span>
                </div>
              </div>

              <!-- Phone -->
              <div class="field-row">
                <div class="field-group">
                  <label for="phone" data-i18n="checkout.field.phone">Phone Number</label>
                  <input type="tel" id="phone" name="phone"
                    data-i18n-ph="checkout.ph.phone" placeholder="+20 100 000 0000"
                    value="<%= formData.phone || '' %>" autocomplete="tel"
                    class="<%= errors.phone ? 'is-invalid' : '' %>" required />
                  <span class="field-error"><%= errors.phone || '' %></span>
                </div>
              </div>

              <!-- Street -->
              <div class="field-row">
                <div class="field-group">
                  <label for="street" data-i18n="checkout.field.street">Street Address</label>
                  <input type="text" id="street" name="street"
                    data-i18n-ph="checkout.ph.street" placeholder="123 Main Street"
                    value="<%= formData.street || '' %>" autocomplete="address-line1"
                    class="<%= errors.street ? 'is-invalid' : '' %>" required />
                  <span class="field-error"><%= errors.street || '' %></span>
                </div>
              </div>

              <!-- Apartment (optional) -->
              <div class="field-row">
                <div class="field-group">
                  <label for="apt">
                    <span data-i18n="checkout.field.apt">Apartment / Suite</span>
                    <span style="color:var(--text-light)" data-i18n="checkout.optional">(optional)</span>
                  </label>
                  <input type="text" id="apt" name="apt"
                    data-i18n-ph="checkout.ph.apt" placeholder="Apt 4B"
                    value="<%= formData.apt || '' %>" autocomplete="address-line2" />
                  <span class="field-error"></span>
                </div>
              </div>

              <!-- City + State -->
              <div class="field-row cols-2">
                <div class="field-group">
                  <label for="city" data-i18n="checkout.field.city">City</label>
                  <input type="text" id="city" name="city"
                    data-i18n-ph="checkout.ph.city" placeholder="Cairo"
                    value="<%= formData.city || '' %>" autocomplete="address-level2"
                    class="<%= errors.city ? 'is-invalid' : '' %>" required />
                  <span class="field-error"><%= errors.city || '' %></span>
                </div>
                <div class="field-group">
                  <label for="state" data-i18n="checkout.field.state">State / Region</label>
                  <input type="text" id="state" name="state"
                    data-i18n-ph="checkout.ph.state" placeholder="Cairo"
                    value="<%= formData.state || '' %>" autocomplete="address-level1"
                    class="<%= errors.state ? 'is-invalid' : '' %>" required />
                  <span class="field-error"><%= errors.state || '' %></span>
                </div>
              </div>

              <!-- ZIP + Country -->
              <div class="field-row cols-2">
                <div class="field-group">
                  <label for="zip" data-i18n="checkout.field.zip">Postal / ZIP Code</label>
                  <input type="text" id="zip" name="zip"
                    data-i18n-ph="checkout.ph.zip" placeholder="12345"
                    value="<%= formData.zip || '' %>" autocomplete="postal-code"
                    class="<%= errors.zip ? 'is-invalid' : '' %>" required />
                  <span class="field-error"><%= errors.zip || '' %></span>
                </div>
                <div class="field-group">
                  <label for="country" data-i18n="checkout.field.country">Country</label>
                  <input type="text" id="country" name="country"
                    data-i18n-ph="checkout.ph.country" placeholder="Egypt"
                    value="<%= formData.country || '' %>" autocomplete="country-name"
                    class="<%= errors.country ? 'is-invalid' : '' %>" required />
                  <span class="field-error"><%= errors.country || '' %></span>
                </div>
              </div>

            </div>
          </div>

          <!-- ── Section 2: Shipping Method ── -->
          <div class="form-section" id="section-shipping">
            <div class="section-header">
              <span class="section-number">2</span>
              <span class="section-title" data-i18n="checkout.s2.title">Shipping Method</span>
              <svg class="section-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M6 9l6 6 6-6"/>
              </svg>
            </div>
            <div class="section-body">
              <div class="shipping-options" role="radiogroup" aria-label="Shipping method">
                <label class="shipping-option">
                  <input type="radio" name="shippingMethod" value="standard"
                    <%= (!formData.shippingMethod || formData.shippingMethod === 'standard') ? 'checked' : '' %> />
                  <div class="shipping-option-label">
                    <span class="shipping-option-name" data-i18n="checkout.ship.standard">Standard Shipping</span>
                    <span class="shipping-option-desc" data-i18n="checkout.ship.standard.desc">5–7 business days</span>
                  </div>
                  <span class="shipping-option-price free" data-i18n="cart.free">Free</span>
                </label>
                <label class="shipping-option">
                  <input type="radio" name="shippingMethod" value="express"
                    <%= formData.shippingMethod === 'express' ? 'checked' : '' %> />
                  <div class="shipping-option-label">
                    <span class="shipping-option-name" data-i18n="checkout.ship.express">Express Shipping</span>
                    <span class="shipping-option-desc" data-i18n="checkout.ship.express.desc">1–2 business days</span>
                  </div>
                  <span class="shipping-option-price">15.00 EGP</span>
                </label>
              </div>
            </div>
          </div>

          <!-- ── Section 3: Payment ── -->
          <div class="form-section" id="section-payment">
            <div class="section-header">
              <span class="section-number">3</span>
              <span class="section-title" data-i18n="checkout.s3.title">Payment</span>
              <svg class="section-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M6 9l6 6 6-6"/>
              </svg>
            </div>
            <div class="section-body">

              <!-- Payment Tabs -->
              <div class="payment-tabs" role="tablist" aria-label="Payment method">
                <button type="button" class="payment-tab active" data-method="card" role="tab" aria-selected="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <rect x="1" y="4" width="22" height="16" rx="2" ry="2"/>
                    <line x1="1" y1="10" x2="23" y2="10"/>
                  </svg>
                  <span data-i18n="checkout.pay.card">Card</span>
                </button>
                <button type="button" class="payment-tab" data-method="cod" role="tab" aria-selected="false">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <rect x="2" y="6" width="20" height="14" rx="2"/>
                    <path d="M2 10h20"/>
                    <circle cx="12" cy="15" r="2"/>
                  </svg>
                  <span data-i18n="checkout.pay.cod">Cash on Delivery</span>
                </button>
              </div>

              <!-- Card Panel -->
              <div class="payment-panel" id="panel-card">
                <div class="field-row">
                  <div class="field-group">
                    <label for="cardNumber" data-i18n="checkout.field.cardNumber">Card Number</label>
                    <div class="card-input-wrap">
                      <input type="text" id="cardNumber" name="cardNumber"
                        data-i18n-ph="checkout.ph.cardNumber" placeholder="1234 5678 9012 3456"
                        inputmode="numeric" maxlength="23"
                        autocomplete="cc-number" class="<%= errors.cardNumber ? 'is-invalid' : '' %>" />
                      <svg class="card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                        <rect x="1" y="4" width="22" height="16" rx="2" ry="2"/>
                        <line x1="1" y1="10" x2="23" y2="10"/>
                      </svg>
                    </div>
                    <span class="field-error"><%= errors.cardNumber || '' %></span>
                  </div>
                </div>

                <div class="field-row cols-3">
                  <div class="field-group">
                    <label for="expiry" data-i18n="checkout.field.expiry">Expiry Date</label>
                    <input type="text" id="expiry" name="expiry"
                      data-i18n-ph="checkout.ph.expiry" placeholder="MM/YY"
                      maxlength="5" inputmode="numeric" autocomplete="cc-exp"
                      class="<%= errors.expiry ? 'is-invalid' : '' %>" />
                    <span class="field-error"><%= errors.expiry || '' %></span>
                  </div>
                  <div class="field-group">
                    <label for="cvv" data-i18n="checkout.field.cvv">CVV</label>
                    <input type="text" id="cvv" name="cvv"
                      data-i18n-ph="checkout.ph.cvv" placeholder="123"
                      maxlength="4" inputmode="numeric" autocomplete="cc-csc"
                      class="<%= errors.cvv ? 'is-invalid' : '' %>" />
                    <span class="field-error"><%= errors.cvv || '' %></span>
                  </div>
                  <div class="field-group">
                    <label for="cardName" data-i18n="checkout.field.cardName">Name on Card</label>
                    <input type="text" id="cardName" name="cardName"
                      data-i18n-ph="checkout.ph.cardName" placeholder="Jane Doe"
                      autocomplete="cc-name" class="<%= errors.cardName ? 'is-invalid' : '' %>" />
                    <span class="field-error"><%= errors.cardName || '' %></span>
                  </div>
                </div>

                <!-- Billing address toggle -->
                <div class="billing-toggle">
                  <label class="checkbox-row">
                    <input type="checkbox" id="billingSame" name="billingSame"
                      <%= (!formData.billingSame || formData.billingSame === 'on') ? 'checked' : '' %> />
                    <span data-i18n="checkout.billing.same">Billing address is the same as shipping</span>
                  </label>

                  <div id="billing-address-section" class="hidden">
                    <div class="field-row" style="margin-top:16px;">
                      <div class="field-group">
                        <label for="billingStreet" data-i18n="checkout.field.billingStreet">Billing Street Address</label>
                        <input type="text" id="billingStreet" name="billingStreet"
                          data-i18n-ph="checkout.ph.billingStreet" placeholder="123 Billing Lane"
                          value="<%= formData.billingStreet || '' %>"
                          class="<%= errors.billingStreet ? 'is-invalid' : '' %>" disabled />
                        <span class="field-error"><%= errors.billingStreet || '' %></span>
                      </div>
                    </div>
                    <div class="field-row">
                      <div class="field-group">
                        <label for="billingApt">
                          <span data-i18n="checkout.field.apt">Apartment / Suite</span>
                          <span style="color:var(--text-light)" data-i18n="checkout.optional">(optional)</span>
                        </label>
                        <input type="text" id="billingApt" name="billingApt"
                          value="<%= formData.billingApt || '' %>" disabled />
                      </div>
                    </div>
                    <div class="field-row cols-2">
                      <div class="field-group">
                        <label for="billingCity" data-i18n="checkout.field.city">City</label>
                        <input type="text" id="billingCity" name="billingCity"
                          value="<%= formData.billingCity || '' %>"
                          class="<%= errors.billingCity ? 'is-invalid' : '' %>" disabled />
                        <span class="field-error"><%= errors.billingCity || '' %></span>
                      </div>
                      <div class="field-group">
                        <label for="billingState" data-i18n="checkout.field.state">State / Region</label>
                        <input type="text" id="billingState" name="billingState"
                          value="<%= formData.billingState || '' %>"
                          class="<%= errors.billingState ? 'is-invalid' : '' %>" disabled />
                        <span class="field-error"><%= errors.billingState || '' %></span>
                      </div>
                    </div>
                  </div>
                </div>

                <p class="security-notice">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                  </svg>
                  <span data-i18n="checkout.security.notice">Your payment information is encrypted and never stored on our servers.</span>
                </p>
              </div>

              <!-- Cash on Delivery Panel -->
              <div class="payment-panel hidden" id="panel-cod">
                <div class="alt-payment-placeholder">
                  <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--text-light)" stroke-width="1.5" aria-hidden="true">
                    <rect x="2" y="6" width="20" height="14" rx="2"/>
                    <path d="M2 10h20"/>
                    <circle cx="12" cy="15" r="2"/>
                  </svg>
                  <p data-i18n="checkout.cod.desc">Pay with cash when your order arrives at your door. No card details needed.</p>
                </div>
              </div>

            </div>
          </div>

          <button type="submit" id="place-order-btn" class="place-order-btn" data-i18n="checkout.place.order">
            Place Order
          </button>

          <p style="text-align:center;font-size:12px;color:var(--text-light);margin-top:16px;line-height:1.6;">
            <span data-i18n="checkout.terms.pre">By placing your order you agree to our</span>
            <a href="/terms" style="color:var(--text-mid);" data-i18n="checkout.terms.link">Terms of Service</a>
            <span data-i18n="checkout.terms.and">and</span>
            <a href="/privacy" style="color:var(--text-mid);" data-i18n="checkout.privacy.link">Privacy Policy</a>.
          </p>

        </form>
      </div>

      <!-- ════ RIGHT — ORDER SUMMARY ════ -->
      <div class="order-summary-col">
        <div class="order-summary">

          <div class="summary-header">
            <h2 data-i18n="cart.summary">Order Summary</h2>
            <p class="item-count">
              <%= cart.length %> <span data-i18n="checkout.items.in">item<%= cart.length !== 1 ? 's' : '' %> in your routine</span>
            </p>
          </div>

          <!-- Cart Items -->
          <div class="cart-items">
            <% cart.forEach(function(item) { %>
              <div class="cart-item">
                <% if (item.image) { %>
                  <img src="<%= item.image %>" alt="<%= item.name %>" class="cart-item-image" loading="lazy" />
                <% } else { %>
                  <div class="cart-item-image-placeholder" data-i18n="checkout.no.img">No img</div>
                <% } %>
                <div class="cart-item-info">
                  <% if (item.step) { %>
                    <p class="cart-item-step"><%= item.step %></p>
                  <% } %>
                  <p class="cart-item-name"><%= item.name %></p>
                  <p class="cart-item-qty"><span data-i18n="checkout.qty">Qty</span>: <%= item.quantity %></p>
                </div>
                <span class="cart-item-price">
                  <%= (item.price * item.quantity).toLocaleString() %> EGP
                </span>
              </div>
            <% }); %>
          </div>

          <!-- Promo Code -->
          <div class="promo-section">
            <div class="promo-row">
              <input type="text" id="promoCode"
                data-i18n-ph="checkout.promo.ph" placeholder="PROMO CODE"
                maxlength="20" aria-label="Promo code" />
              <button type="button" id="apply-promo-btn" data-i18n="checkout.promo.apply">Apply</button>
            </div>
            <p class="promo-message" id="promo-message" role="status"></p>
          </div>

          <!-- Price Breakdown -->
          <div class="price-breakdown">
            <div class="price-row">
              <span class="label" data-i18n="cart.subtotal">Subtotal</span>
              <span class="value" id="js-subtotal" data-value="<%= subtotal %>">
                <%= parseFloat(subtotal).toLocaleString() %> EGP
              </span>
            </div>
            <div class="price-row discount hidden">
              <span class="label" data-i18n="checkout.discount">Discount</span>
              <span class="value" id="js-discount" data-value="0">-0.00 EGP</span>
            </div>
            <div class="price-row">
              <span class="label" data-i18n="cart.shipping">Shipping</span>
              <span class="value" id="js-shipping-display" data-i18n="cart.free">Free</span>
              <input type="hidden" id="js-shipping-value" name="shippingCost" value="0" />
            </div>
            <div class="price-row">
              <span class="label" data-i18n="checkout.tax">Tax (8.5%)</span>
              <span class="value" id="js-tax-display">
                <%= (parseFloat(subtotal) * 0.085).toLocaleString() %> EGP
              </span>
            </div>
            <div class="price-row total">
              <span class="label" data-i18n="cart.total">Total</span>
              <span class="value" id="js-total-display">
                <%= (parseFloat(subtotal) * 1.085).toLocaleString() %> EGP
              </span>
            </div>
          </div>

          <!-- Trust badges -->
          <div class="trust-badges" aria-label="Trust signals">
            <div class="trust-badge">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
              <span data-i18n="checkout.badge.secure">Secure</span>
            </div>
            <div class="trust-badge">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              <span data-i18n="checkout.badge.verified">Verified</span>
            </div>
            <div class="trust-badge">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
              <span data-i18n="checkout.badge.fast">Fast Ship</span>
            </div>
          </div>

        </div>
      </div>

    </div>
  </main>

  <script src="/js/i18n.js"></script>
  <script src="/js/checkout.js"></script>
  <script>
    // Remove language button injected by i18n.js
    document.addEventListener('DOMContentLoaded', function() {
      var langBtn = document.getElementById('lang-switcher');
      if (langBtn) langBtn.remove();
    });
  </script>
</body>
</html>
