<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Skin Advisor | Lumiskin</title>
  <link rel="stylesheet" href="/css/header.css" />
  <style>
    body { font-family: 'Segoe UI', sans-serif; background: #faf8f5; margin: 0; }

    .advisor-hero {
      text-align: center;
      padding: 100px 24px 40px;
      background: linear-gradient(160deg, #fff8f2 0%, #faf6f1 100%);
    }
    .advisor-hero .eyebrow {
      font-size: 11px; letter-spacing: 2.5px; text-transform: uppercase;
      color: #b5814a; margin-bottom: 12px; font-weight: 600;
    }
    .advisor-hero h1 {
      font-size: clamp(28px, 5vw, 48px);
      font-weight: 700; margin-bottom: 14px; color: #2a2018;
    }
    .advisor-hero p {
      color: #8a7d70; max-width: 520px; margin: 0 auto 32px; line-height: 1.7;
    }

    .city-form {
      display: flex; max-width: 480px; margin: 0 auto;
      border: 1.5px solid #e0d4c8; border-radius: 40px;
      overflow: hidden; background: #fff;
      box-shadow: 0 2px 18px rgba(0,0,0,.07);
      transition: border-color .2s;
    }
    .city-form:focus-within { border-color: #b5814a; }
    #cityInput {
      flex: 1; padding: 13px 22px; border: none; outline: none;
      font-size: 15px; background: transparent; color: #2a2018;
    }
    #cityInput::placeholder { color: #b0a49a; }
    #searchBtn {
      padding: 12px 26px; background: #b5814a; color: #fff;
      border: none; font-size: 14px; font-weight: 600;
      cursor: pointer; transition: background .2s;
      border-radius: 0 40px 40px 0;
    }
    #searchBtn:hover { background: #8c5e2a; }
    #searchBtn:disabled { opacity: .5; cursor: not-allowed; }

    .loader-wrap { text-align: center; padding: 48px; display: none; }
    .spinner {
      display: inline-block; width: 40px; height: 40px;
      border: 3px solid #e0d4c8; border-top-color: #b5814a;
      border-radius: 50%; animation: spin .8s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    .error-box {
      max-width: 500px; margin: 28px auto; padding: 16px 22px;
      background: #fff5f5; border: 1px solid #f5c0c0;
      border-radius: 10px; color: #c94040; text-align: center; display: none;
    }

    .results { max-width: 960px; margin: 0 auto; padding: 24px 20px 80px; display: none; }

    .weather-banner {
      display: flex; align-items: center; flex-wrap: wrap; gap: 28px;
      background: #fff; border: 1px solid #e8ddd4;
      border-radius: 16px; padding: 28px 32px; margin-bottom: 24px;
      box-shadow: 0 2px 14px rgba(0,0,0,.05);
      animation: fadeUp .4s ease;
    }
    @keyframes fadeUp { from { opacity:0; transform:translateY(16px); } to { opacity:1; transform:translateY(0); } }

    .city-name { font-size: 22px; font-weight: 700; color: #2a2018; margin-bottom: 4px; }
    .stats { display: flex; gap: 24px; flex-wrap: wrap; margin-top: 10px; }
    .stat { display: flex; flex-direction: column; }
    .stat .val { font-size: 24px; font-weight: 700; color: #b5814a; }
    .stat .lbl { font-size: 11px; color: #8a7d70; text-transform: uppercase; letter-spacing: .5px; }

    .uv-pill {
      margin-left: auto; padding: 10px 22px; border-radius: 40px;
      font-size: 15px; font-weight: 700; min-width: 90px; text-align: center;
    }
    .uv-low    { background: #e8f8f0; color: #1a6640; }
    .uv-medium { background: #fffbea; color: #7a5a00; }
    .uv-high   { background: #fff0f0; color: #8b1a1a; }

    .urgency-strip {
      border-radius: 10px; padding: 12px 20px; margin-bottom: 22px;
      font-size: 14px; font-weight: 500;
      animation: fadeUp .35s ease;
    }
    .urg-low    { background: #e8f8f0; border: 1px solid #9adcba; color: #1a5c35; }
    .urg-medium { background: #fffbea; border: 1px solid #f5d87a; color: #7a5000; }
    .urg-high   { background: #fff0f0; border: 1px solid #f5b0b0; color: #8b1a1a; }

    .advice-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px; }
    @media(max-width: 640px) { .advice-grid { grid-template-columns: 1fr; } }

    .advice-card {
      background: #fff; border: 1px solid #e8ddd4;
      border-radius: 14px; padding: 24px;
      box-shadow: 0 2px 10px rgba(0,0,0,.04);
      animation: fadeUp .5s ease backwards;
    }
    .advice-card h3 { font-size: 14px; font-weight: 700; color: #8c5e2a; margin: 0 0 14px; }

    .tip-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 9px; }
    .tip-list li {
      font-size: 13.5px; line-height: 1.6; padding: 10px 14px;
      background: #faf6f1; border-radius: 8px;
      border-left: 3px solid #b5814a;
    }

    .tag-list { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 14px; }
    .tag-chip {
      display: inline-flex; align-items: center; gap: 5px;
      background: #fff8f2; border: 1px solid #e8cdb0;
      color: #8c5e2a; border-radius: 20px;
      padding: 7px 15px; font-size: 13px; font-weight: 500;
      cursor: pointer; transition: .2s; text-decoration: none;
    }
    .tag-chip:hover { background: #b5814a; color: #fff; border-color: #b5814a; }

    .fact-card {
      background: linear-gradient(135deg, #fff8f0, #fff);
      border: 1px solid #e8cdb0; border-radius: 14px;
      padding: 22px 26px;
      animation: fadeUp .6s ease backwards;
    }
    .fact-label {
      font-size: 11px; font-weight: 700; color: #b5814a;
      text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 8px;
    }
    .fact-card p { font-size: 14px; color: #4a3c30; line-height: 1.7; margin: 0 0 12px; }

    .shop-btn {
      display: inline-block; background: #b5814a; color: #fff;
      padding: 10px 24px; border-radius: 30px;
      text-decoration: none; font-size: 13px; font-weight: 600;
      transition: background .2s;
    }
    .shop-btn:hover { background: #8c5e2a; }

    .api-note { text-align: center; font-size: 11px; color: #b0a49a; padding: 16px; }
    .api-note a { color: #b5814a; }
  </style>
</head>
<body>

<%- include('partials/header') %>

<!-- ── Hero ──────────────────────────────────────────────── -->
<section class="advisor-hero">
  <p class="eyebrow" data-i18n="advisor.eyebrow">External API · Open-Meteo · No API Key Required</p>
  <h1 data-i18n="advisor.title">Your Daily Skin Advisor</h1>
  <p data-i18n="advisor.sub">Enter your city to get real-time UV index, temperature, and humidity — plus personalised skincare tips for today.</p>

  <div class="city-form">
    <input type="text" id="cityInput" data-i18n-ph="advisor.placeholder" placeholder="Enter city (e.g. Cairo, London, Dubai)" autocomplete="off" />
    <button id="searchBtn" data-i18n="advisor.btn">Analyse</button>
  </div>
</section>

<!-- ── Loading / Error states ─────────────────────────────── -->
<div class="loader-wrap" id="loader">
  <div class="spinner"></div>
  <p style="margin-top:14px;color:#8a7d70;font-size:14px" data-i18n="advisor.loading">Fetching real-time weather data…</p>
</div>
<div class="error-box" id="errorBox"></div>

<!-- ── Results ────────────────────────────────────────────── -->
<section class="results" id="results">

  <div class="urgency-strip" id="urgencyStrip"></div>

  <div class="weather-banner" id="weatherBanner">
    <div>
      <div class="city-name" id="wCity">—</div>
      <div style="font-size:13px;color:#8a7d70" id="wTime">—</div>
      <div class="stats">
        <div class="stat"><span class="val" id="wTemp">—</span><span class="lbl">Temp °C</span></div>
        <div class="stat"><span class="val" id="wHumid">—</span><span class="lbl">Humidity %</span></div>
        <div class="stat"><span class="val" id="wUV">—</span><span class="lbl">UV Index</span></div>
      </div>
    </div>
    <div class="uv-pill" id="uvPill">UV 0</div>
  </div>

  <div class="advice-grid">
    <div class="advice-card" style="animation-delay:.1s">
      <h3 data-i18n="advisor.tips.title">Today's Skincare Tips</h3>
      <ul class="tip-list" id="tipsList"></ul>
    </div>
    <div class="advice-card" style="animation-delay:.2s">
      <h3 data-i18n="advisor.products.title">Recommended Products</h3>
      <div class="tag-list" id="tagList"></div>
      <a href="/cerave" class="shop-btn" data-i18n="advisor.browse">Browse All Products &rarr;</a>
    </div>
  </div>

  <div class="fact-card" style="animation-delay:.3s" id="factCard">
    <div class="fact-label" data-i18n="advisor.fact.label">Skin Fact of the Day</div>
    <p id="factText" data-i18n="advisor.fact.loading">Loading…</p>
  </div>

</section>

<p class="api-note">
  Weather &amp; UV data:
  <a href="https://open-meteo.com" target="_blank">Open-Meteo API</a> (free, no key) &middot;
  Geocoding: <a href="https://nominatim.openstreetmap.org" target="_blank">OpenStreetMap Nominatim</a>
</p>

<script>
document.addEventListener('DOMContentLoaded', function () {

  var cityInput = document.getElementById('cityInput');
  var searchBtn = document.getElementById('searchBtn');
  var loader    = document.getElementById('loader');
  var errorBox  = document.getElementById('errorBox');
  var results   = document.getElementById('results');

  cityInput.value = 'Cairo';
  analyse('Cairo');
  loadFact();

  searchBtn.addEventListener('click', function () {
    var city = cityInput.value.trim();
    if (!city) { cityInput.focus(); return; }
    analyse(city);
  });

  cityInput.addEventListener('keydown', function (e) {
    if (e.key === 'Enter') searchBtn.click();
  });

  document.addEventListener('langchange', function () {
    var city = cityInput.value.trim();
    if (city) analyse(city);
  });

  async function geocode(city) {
    var url = 'https://nominatim.openstreetmap.org/search?q=' + encodeURIComponent(city) + '&format=json&limit=1';
    var res  = await fetch(url, { headers: { 'Accept-Language': 'en' } });
    var data = await res.json();
    if (!data.length) throw new Error('City "' + city + '" not found. Try a different spelling.');
    return {
      lat: parseFloat(data[0].lat),
      lon: parseFloat(data[0].lon),
      display: data[0].display_name.split(',').slice(0, 2).join(', ')
    };
  }

  async function getWeather(lat, lon) {
    var res  = await fetch('/api/uv-index?lat=' + lat + '&lon=' + lon, {
      headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }
    });
    var data = await res.json();
    if (!data.success) throw new Error(data.error || 'Could not fetch weather data.');
    return data;
  }

  async function analyse(city) {
    setLoading(true);
    errorBox.style.display = 'none';
    try {
      var geo     = await geocode(city);
      var weather = await getWeather(geo.lat, geo.lon);
      render(geo, weather);
    } catch (err) {
      showError(err.message);
    } finally {
      setLoading(false);
    }
  }

  function render(geo, w) {
    var t = window.LumiI18n ? window.LumiI18n.t.bind(window.LumiI18n) : function(k){ return k; };

    document.getElementById('wCity').textContent  = geo.display;
    document.getElementById('wTime').textContent  = w.time ? t('advisor.data.for') + w.time.replace('T', ' ') : '';
    document.getElementById('wTemp').textContent  = w.temperature + '°';
    document.getElementById('wHumid').textContent = w.humidity + '%';
    document.getElementById('wUV').textContent    = w.uv_index;

    var uv     = w.uv_index;
    var uvPill = document.getElementById('uvPill');
    uvPill.textContent = 'UV ' + uv;
    uvPill.className   = 'uv-pill ' + (uv >= 8 ? 'uv-high' : uv >= 3 ? 'uv-medium' : 'uv-low');

    var advice  = buildAdvice(w);
    var tips    = advice.tips;
    var tags    = advice.tags;
    var urgency = advice.urgency;

    var strip  = document.getElementById('urgencyStrip');
    var urgMap = {
      high:   ['urg-high',   t('advisor.urg.high')],
      medium: ['urg-medium', t('advisor.urg.medium')],
      low:    ['urg-low',    t('advisor.urg.low')]
    };
    strip.className   = 'urgency-strip ' + urgMap[urgency][0];
    strip.textContent = urgMap[urgency][1];

    document.getElementById('tipsList').innerHTML = tips.map(function(tip){ return '<li>' + tip + '</li>'; }).join('');

    var tagList = document.getElementById('tagList');
    tagList.innerHTML = tags.length
      ? tags.map(function(tag){ return '<a href="/cerave" class="tag-chip">' + tag.label + ' <span style="font-size:10px;opacity:.6">shop &rarr;</span></a>'; }).join('')
      : '<p style="color:#8a7d70;font-size:13px">' + t('advisor.protected') + '</p>';

    errorBox.style.display = 'none';
    results.style.display  = 'block';
  }

  function buildAdvice(data) {
    var t = window.LumiI18n ? window.LumiI18n.t.bind(window.LumiI18n) : function(k){ return k; };
    var uv       = data.uv_index;
    var temp     = data.temperature;
    var humidity = data.humidity;
    var tips    = [];
    var tags    = [];
    var urgency = 'low';

    if (uv >= 8) {
      urgency = 'high';
      tips.push(t('advisor.tip.uv.high'));
      tags.push({ label: t('advisor.tag.spf50') });
    } else if (uv >= 3) {
      urgency = urgency === 'low' ? 'medium' : urgency;
      tips.push(t('advisor.tip.uv.med'));
      tags.push({ label: t('advisor.tag.spf') });
    } else {
      tips.push(t('advisor.tip.uv.low'));
    }

    if (humidity < 35) {
      urgency = urgency === 'low' ? 'medium' : urgency;
      tips.push(t('advisor.tip.dry'));
      tags.push({ label: t('advisor.tag.moist') });
    } else if (humidity > 72) {
      tips.push(t('advisor.tip.humid'));
      tags.push({ label: t('advisor.tag.cleanser') });
    } else {
      tips.push(t('advisor.tip.humid.ok'));
    }

    if (temp >= 30) {
      tips.push(t('advisor.tip.hot'));
      tags.push({ label: t('advisor.tag.light') });
    } else if (temp <= 12) {
      tips.push(t('advisor.tip.cold'));
      tags.push({ label: t('advisor.tag.barrier') });
    }

    if (uv >= 6 && humidity < 40) {
      tips.push(t('advisor.tip.combo'));
    }

    var seen     = new Set();
    var uniqueTags = tags.filter(function(tag) {
      if (seen.has(tag.label)) return false;
      seen.add(tag.label); return true;
    });

    return { tips: tips, tags: uniqueTags, urgency: urgency };
  }

  async function loadFact() {
    try {
      var res  = await fetch('/api/skin-fact');
      var data = await res.json();
      document.getElementById('factText').textContent = data.fact;
    } catch (e) {
      document.getElementById('factText').textContent = 'SPF 30 blocks 97% of UVB rays — and reapplication matters more than a higher number.';
    }
  }

  function setLoading(on) {
    var t = window.LumiI18n ? window.LumiI18n.t.bind(window.LumiI18n) : function(k){ return k; };
    loader.style.display  = on ? 'block' : 'none';
    if (on) results.style.display = 'none';
    searchBtn.disabled    = on;
    searchBtn.textContent = on ? t('advisor.btn.loading') : t('advisor.btn');
  }

  function showError(msg) {
    var t = window.LumiI18n ? window.LumiI18n.t.bind(window.LumiI18n) : function(k){ return k; };
    errorBox.textContent   = t('advisor.error') + msg;
    errorBox.style.display = 'block';
    results.style.display  = 'none';
  }

});
</script>
</body>
</html>




