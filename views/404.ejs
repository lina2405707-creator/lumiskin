<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lumiskin — Page Not Found</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', sans-serif;
            background-color: #fdf8f4;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100vh;
            text-align: center;
            padding: 20px;
        }

        .logo {
            font-size: 32px;
            font-weight: bold;
            color: rgb(147, 97, 62);
            font-style: italic;
            margin-bottom: 40px;
            text-decoration: none;
        }

        .code {
            font-size: 100px;
            font-weight: 900;
            color: rgb(220, 195, 175);
            line-height: 1;
        }

        h1 {
            font-size: 28px;
            color: rgb(147, 97, 62);
            margin: 16px 0 10px;
        }

        p {
            font-size: 16px;
            color: #999;
            margin-bottom: 36px;
        }

        .btn {
            padding: 12px 32px;
            background-color: rgb(163, 108, 69);
            color: #fff;
            border-radius: 50px;
            text-decoration: none;
            font-weight: 700;
            font-size: 15px;
            transition: background 0.2s;
        }

        .btn:hover {
            background-color: rgb(140, 90, 55);
        }
    </style>
</head>

<body>
    <a href="/" class="logo">Lumiskin</a>
    <div class="code">404</div>
    <h1>Page Not Found</h1>
    <p>The page you're looking for doesn't exist or has been moved.</p>
    <a href="/" class="btn">Back to Home</a>
</body>

</html>